@rendermode InteractiveServer
@inject AdminThemeState ThemeState
@inject NavigationManager Navigation
@implements IDisposable

<MudThemeProvider IsDarkMode="@EffectiveIsDarkMode"
                  IsDarkModeChanged="OnDarkModeChangedAsync"
                  Theme="@AdminThemes.Default"
                  ObserveSystemDarkModeChange="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <RedirectToLogin />
                    }
                    else
                    {
                        <MudText Color="Color.Error">Acesso negado.</MudText>
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
    </Router>
</CascadingAuthenticationState>

@code {
    private bool _isLoginRoute;

    private bool EffectiveIsDarkMode => !_isLoginRoute && ThemeState.IsDarkMode;

    protected override void OnInitialized()
    {
        ThemeState.ChangedAsync += OnThemeChangedAsync;
        Navigation.LocationChanged += OnLocationChanged;
        UpdateIsLoginRoute();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await ThemeState.InitializeAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateIsLoginRoute();
        _ = InvokeAsync(StateHasChanged);
    }

    private void UpdateIsLoginRoute()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).TrimEnd('/');
        _isLoginRoute = path.Equals("login", StringComparison.OrdinalIgnoreCase);
    }

    private Task OnThemeChangedAsync() => InvokeAsync(StateHasChanged);

    private async Task OnDarkModeChangedAsync(bool value)
    {
        if (_isLoginRoute)
            return;

        await ThemeState.SetDarkModeAsync(value);
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeState.ChangedAsync -= OnThemeChangedAsync;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
