@page "/"
@page "/admin/dashboard"
@attribute [Authorize]

@using TeacherApp.Contracts.Admin

@inject HttpClient Http

<PageTitle>Dashboard — TeacherApp Admin</PageTitle>

@* Cabeçalho no mesmo padrão de Módulos / Lições (my-4, h4 + subtítulo secundário). *@
<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="my-4">
    <div>
        <MudText Typo="Typo.h4">Dashboard</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Welcome back!</MudText>
    </div>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_stats is null)
{
    @if (!string.IsNullOrEmpty(_error))
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
}
else
{
    @* Ícones alinhados ao Figma Make (lucide-react): Users, BookOpen, FileText → Material equivalentes. *@
    <MudGrid Spacing="4" Class="mb-4">
        <MudItem xs="12" sm="6" lg="4">
            <MudCard Class="rounded-xl" Style="border: 1px solid var(--mud-palette-lines-default);" Elevation="0">
                <MudCardContent Class="pa-6">
                    <div class="d-flex align-start justify-space-between mb-4">
                        <MudPaper Class="pa-3 rounded-lg d-flex align-center justify-center"
                                  Style="background-color: rgba(var(--mud-palette-primary-rgb), 0.12); box-shadow: none;"
                                  Elevation="0">
                            <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Size="Size.Medium" />
                        </MudPaper>
                    </div>
                    <MudText Typo="Typo.h4">@_stats.TotalStudents</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Students</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" lg="4">
            <MudCard Class="rounded-xl" Style="border: 1px solid var(--mud-palette-lines-default);" Elevation="0">
                <MudCardContent Class="pa-6">
                    <div class="d-flex align-start justify-space-between mb-4">
                        <MudPaper Class="pa-3 rounded-lg d-flex align-center justify-center"
                                  Style="background-color: rgba(var(--mud-palette-primary-rgb), 0.12); box-shadow: none;"
                                  Elevation="0">
                            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Primary" Size="Size.Medium" />
                        </MudPaper>
                    </div>
                    <MudText Typo="Typo.h4">@_stats.TotalModules</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Modules</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" lg="4">
            <MudCard Class="rounded-xl" Style="border: 1px solid var(--mud-palette-lines-default);" Elevation="0">
                <MudCardContent Class="pa-6">
                    <div class="d-flex align-start justify-space-between mb-4">
                        <MudPaper Class="pa-3 rounded-lg d-flex align-center justify-center"
                                  Style="background-color: rgba(var(--mud-palette-primary-rgb), 0.12); box-shadow: none;"
                                  Elevation="0">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Size="Size.Medium" />
                        </MudPaper>
                    </div>
                    <MudText Typo="Typo.h4">@_stats.TotalLessons</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total Lessons</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudPaper Class="pa-6 rounded-xl" Style="border: 1px solid var(--mud-palette-lines-default);" Elevation="0">
        @* Alinhado ao Figma Make (Dashboard.tsx): Recent Activity; sem filtro por aluno. *@
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-4">
            <div>
                <MudText Typo="Typo.h6">Atividade recente</MudText>
            </div>
            <MudTooltip Text="Atualizar lista">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Color="Color.Primary"
                               Disabled="@_tableLoading"
                               OnClick="@(() => ReloadCompletionsAsync())" />
            </MudTooltip>
        </MudStack>

        @if (_tableLoading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_completions.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">Nenhuma lição concluída encontrada.</MudText>
        }
        else
        {
            <MudTable Items="@_completions" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm" Dense="true">
                <HeaderContent>
                    <MudTh>Aluno</MudTh>
                    <MudTh>Módulo</MudTh>
                    <MudTh>Lição</MudTh>
                    <MudTh>Concluída em</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Aluno">
                        <div>
                            <MudText Typo="Typo.body2" Style="font-weight:500;">@context.StudentFullName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.StudentEmail</MudText>
                        </div>
                    </MudTd>
                    <MudTd DataLabel="Módulo">@context.ModuleTitle</MudTd>
                    <MudTd DataLabel="Lição">@context.LessonTitle</MudTd>
                    <MudTd DataLabel="Concluída em">@FormatCompletedAt(context.CompletedAt)</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
}

@if (!string.IsNullOrEmpty(_error) && _stats is not null)
{
    <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
}

@code {
    private DashboardAdminStatsResponse? _stats;
    private readonly List<CompletedLessonAdminRowResponse> _completions = [];
    private bool _loading = true;
    private bool _tableLoading;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _stats = await Http.GetFromJsonAsync<DashboardAdminStatsResponse>("api/v1/admin/dashboard/stats");
            await ReloadCompletionsAsync(skipLoadingFlags: true);
        }
        catch (HttpRequestException)
        {
            _error = "Não foi possível conectar à API.";
            _stats = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ReloadCompletionsAsync(bool skipLoadingFlags = false)
    {
        if (!skipLoadingFlags)
            _tableLoading = true;
        try
        {
            const string url = "api/v1/admin/dashboard/completed-lessons?take=50";
            var rows = await Http.GetFromJsonAsync<List<CompletedLessonAdminRowResponse>>(url);
            _completions.Clear();
            if (rows is not null)
                _completions.AddRange(rows);
        }
        catch (HttpRequestException)
        {
            _error = "Não foi possível carregar as lições concluídas.";
        }
        finally
        {
            if (!skipLoadingFlags)
                _tableLoading = false;
        }
    }

    private static string FormatCompletedAt(DateTimeOffset utc)
        => utc.ToLocalTime().ToString("g");
}
