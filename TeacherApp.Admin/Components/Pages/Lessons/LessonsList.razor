@page "/lessons"
@attribute [Authorize]

@inject HttpClient Http
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>Lições — TeacherApp Admin</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="my-4">
    <div>
        <MudText Typo="Typo.h4">Lições</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Gerencie o conteúdo das lições</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(async () => await OpenNewLessonAsync())" Disabled="@(_modules.Count == 0)">Nova Lição</MudButton>
</MudStack>

@* Filtros alinhados ao admin/Lessons.tsx (Figma Make): flex-row + gap, busca em flex:1 + input w-full, módulo à direita (flex:0) *@
<div class="mb-4" style="width:100%; display:flex; flex-wrap:wrap; align-items:flex-end; gap:16px;">
    <div style="flex:1 1 12rem; min-width:0;">
        <MudTextField T="string"
                      @bind-Value="_searchTerm"
                      @bind-Value:after="OnSearchChanged"
                      Placeholder="Buscar lições..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      DebounceInterval="250"
                      FullWidth="true" />
    </div>
    <div style="flex:0 0 auto; min-width:12.5rem; max-width:100%;">
        <MudSelect T="Guid?"
                   Value="_filterModuleId"
                   ValueChanged="OnModuleFilterChangedAsync"
                   Label="Módulo"
                   Clearable="true"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   FullWidth="true">
            <MudSelectItem T="Guid?" Value="@null">Todos</MudSelectItem>
            @foreach (var m in _modules)
            {
                <MudSelectItem T="Guid?" Value="@m.Id">@m.Title</MudSelectItem>
            }
        </MudSelect>
    </div>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (FilteredLessons.Count == 0)
{
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        @(string.IsNullOrWhiteSpace(_searchTerm)
            ? "Nenhuma lição encontrada."
            : "Nenhum resultado para a busca.")
    </MudText>
}
else
{
    <MudTable Items="@FilteredLessons" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Título</MudTh>
            <MudTh>Módulo</MudTh>
            <MudTh>Áudio</MudTh>
            <MudTh Style="width: 200px;">Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Título">@context.Title</MudTd>
            <MudTd DataLabel="Módulo">@(_modules.FirstOrDefault(m => m.Id == context.ModuleId)?.Title ?? "—")</MudTd>
            <MudTd DataLabel="Áudio">
                @if (!string.IsNullOrEmpty(context.AudioFileName))
                {
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.AudioFile" Size="Size.Small" Color="Color.Primary" />
                        <MudText Typo="Typo.body2">@context.AudioFileName</MudText>
                    </MudStack>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Ações">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="@(async () => await OpenFormAsync(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => Delete(context.Id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudDialog Visible="_showForm" VisibleChanged="OnLessonFormVisibleChanged" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editing is null ? "Nova Lição" : "Editar Lição")</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="_form" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <MudStack Spacing="3">
                @if (_editing is not null)
                {
                    <MudSelect T="Guid"
                               @key="_editing.Id"
                               Value="_editing.Id"
                               ValueChanged="OnSwitchEditingLessonAsync"
                               Label="Lição"
                               Variant="Variant.Outlined"
                               Dense="true">
                        @foreach (var l in LessonsForPicker)
                        {
                            var modTitle = _modules.FirstOrDefault(m => m.Id == l.ModuleId)?.Title ?? "—";
                            <MudSelectItem T="Guid" Value="@l.Id">@l.Title · @modTitle</MudSelectItem>
                        }
                    </MudSelect>
                }
                <MudTextField @bind-Value="_form.Title" For="@(() => _form.Title)" Label="Título da lição" Variant="Variant.Outlined" />
                <MudSelect T="string" @bind-Value="_form.ModuleId" Label="Módulo" Variant="Variant.Outlined" Required="true">
                    @foreach (var m in _modules)
                    {
                        <MudSelectItem T="string" Value="@m.Id.ToString()">@m.Title</MudSelectItem>
                    }
                </MudSelect>
                <MudTextField @bind-Value="_form.Description" Label="Conteúdo da lição" Variant="Variant.Outlined" Lines="10"
                              Placeholder="Escreva o conteúdo de leitura para os alunos..." />
                <MudText Typo="Typo.caption" Color="Color.Secondary">Material de leitura apresentado aos alunos</MudText>
                <MudNumericField @bind-Value="_form.Order" Label="Ordem" Variant="Variant.Outlined" Min="0" />

                @* Audio File *@
                <MudText Typo="Typo.body2" Class="mt-2">Arquivo de áudio</MudText>
                @if (_form.AudioMediaId is null)
                {
                    <div @onclick="@(() => _showAudioPicker = true)"
                         style="border: 2px dashed var(--mud-palette-lines-default); border-radius: 8px; padding: 24px; text-align: center; cursor: pointer;">
                        <MudIcon Icon="@Icons.Material.Filled.AudioFile" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body1" Class="mt-2">Escolher áudio da biblioteca</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Selecione um arquivo de áudio já enviado na página Mídia</MudText>
                    </div>
                }
                else
                {
                    <MudPaper Outlined="true" Class="pa-4 rounded-lg">
                        <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                            <MudAvatar Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Large">
                                <MudIcon Icon="@Icons.Material.Filled.AudioFile" />
                            </MudAvatar>
                            <MudStack Spacing="0" Style="flex:1; min-width:0;">
                                <MudText Typo="Typo.subtitle2" Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                    @(_form.AudioFileName ?? "Áudio selecionado")
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@_form.AudioMediaId</MudText>
                            </MudStack>
                            <MudStack Row="true" Spacing="1">
                                <MudTooltip Text="Reproduzir">
                                    <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Size="Size.Small" Color="Color.Primary"
                                                   OnClick="@StartLessonAudioPreviewAsync" />
                                </MudTooltip>
                                <MudTooltip Text="Trocar áudio">
                                    <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" Color="Color.Primary"
                                                   OnClick="@(() => _showAudioPicker = true)" />
                                </MudTooltip>
                                <MudTooltip Text="Remover áudio">
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error"
                                                   OnClick="@ClearLessonAudioAsync" />
                                </MudTooltip>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                }

                @if (_playingLessonPreviewName is not null)
                {
                    <MudPaper Elevation="1" Outlined="true" Class="pa-3">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.MusicNote" Color="Color.Primary" />
                                <MudText Typo="Typo.body2" Style="flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis;">@_playingLessonPreviewName</MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@StopLessonPreviewAsync" />
                            </MudStack>
                            <audio id="lesson-dialog-audio-player" controls autoplay style="width:100%;"></audio>
                        </MudStack>
                    </MudPaper>
                }

                @if (!string.IsNullOrEmpty(_formError))
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_formError</MudAlert>
                }
                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                    <MudButton Variant="Variant.Text" OnClick="@CloseFormAsync">Cancelar</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Disabled="_saving">
                        @if (_saving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        }
                        else
                        {
                            <span>Salvar</span>
                        }
                    </MudButton>
                </MudStack>
            </MudStack>
        </EditForm>
    </DialogContent>
</MudDialog>

<MudDialog @bind-Visible="_showAudioPicker" Options="_audioPickerDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">Selecionar áudio</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string"
                      @bind-Value="_audioSearchTerm"
                      Placeholder="Buscar áudio..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      DebounceInterval="200"
                      Class="mb-3" />
        @if (FilteredAudioMedia.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4" Align="Align.Center">
                Nenhum áudio encontrado. Envie arquivos na página Mídia.
            </MudText>
        }
        else
        {
            <MudList T="Guid" Dense="true" Style="max-height: 320px; overflow-y: auto;">
                @foreach (var media in FilteredAudioMedia)
                {
                    <MudListItem T="Guid" OnClick="@(() => SelectAudio(media))">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.AudioFile" Size="Size.Small" Color="Color.Primary" />
                            <MudStack Spacing="0" Style="flex:1; min-width:0;">
                                <MudText Typo="Typo.body2" Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@media.FileName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatBytes(media.SizeBytes)</MudText>
                            </MudStack>
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        }
    </DialogContent>
</MudDialog>

@if (!string.IsNullOrEmpty(_error))
{
    <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
}

@code {
    private static readonly DialogOptions _dialogOptions = new()
    {
        CloseButton = true,
        FullWidth = true,
        MaxWidth = MaxWidth.Medium,
        BackdropClick = true
    };

    private List<TeacherApp.Contracts.Modules.ModuleResponse> _modules = [];
    private List<TeacherApp.Contracts.Lessons.LessonResponse> _lessons = [];
    private List<TeacherApp.Contracts.Lessons.LessonResponse> _lessonPickerList = [];
    private bool _lessonPickerReady;
    private List<TeacherApp.Contracts.Media.MediaResponse> _audioMedia = [];
    private bool _loading = true;
    private string? _error;
    private Guid? _filterModuleId;
    private string? _searchTerm;

    private List<TeacherApp.Contracts.Lessons.LessonResponse> FilteredLessons =>
        _lessons
            .Where(l => string.IsNullOrWhiteSpace(_searchTerm)
                || l.Title.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
                || (_modules.FirstOrDefault(m => m.Id == l.ModuleId)?.Title?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
            .OrderBy(l => l.Order)
            .ToList();

    private void OnSearchChanged() { }

    private IEnumerable<TeacherApp.Contracts.Lessons.LessonResponse> LessonsForPicker =>
        _lessonPickerList
            .OrderBy(l => _modules.FirstOrDefault(m => m.Id == l.ModuleId)?.Title ?? "\uFFFF", StringComparer.OrdinalIgnoreCase)
            .ThenBy(l => l.Order)
            .ThenBy(l => l.Title, StringComparer.OrdinalIgnoreCase);

    private bool _showForm;
    private bool _saving;
    private string? _formError;
    private TeacherApp.Contracts.Lessons.LessonResponse? _editing;
    private LessonFormModel _form = new();
    private string? _audioSearchTerm;
    private bool _showAudioPicker;
    private string? _playingLessonPreviewName;

    private List<TeacherApp.Contracts.Media.MediaResponse> FilteredAudioMedia =>
        _audioMedia
            .Where(m => string.IsNullOrWhiteSpace(_audioSearchTerm)
                || m.FileName.Contains(_audioSearchTerm, StringComparison.OrdinalIgnoreCase))
            .ToList();

    private sealed class LessonFormModel
    {
        public string ModuleId { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Título obrigatório")]
        public string Title { get; set; } = "";
        public string? Description { get; set; }
        public int Order { get; set; } = 1;

        public Guid? AudioMediaId { get; set; }
        public string? AudioFileName { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _modules = await Http.GetFromJsonAsync<List<TeacherApp.Contracts.Modules.ModuleResponse>>("api/v1/admin/modules") ?? [];
        await LoadMediaAsync();
        await LoadAsync();
    }

    private async Task LoadMediaAsync()
    {
        try
        {
            var all = await Http.GetFromJsonAsync<List<TeacherApp.Contracts.Media.MediaResponse>>("api/v1/admin/media") ?? [];
            _audioMedia = all
                .Where(m => m.UploadCompleted && m.ContentType.StartsWith("audio/", StringComparison.OrdinalIgnoreCase))
                .OrderBy(m => m.FileName)
                .ToList();
        }
        catch (HttpRequestException)
        {
            _audioMedia = [];
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            var query = _filterModuleId.HasValue ? $"?moduleId={_filterModuleId}" : "";
            _lessons = await Http.GetFromJsonAsync<List<TeacherApp.Contracts.Lessons.LessonResponse>>($"api/v1/admin/lessons{query}") ?? [];
        }
        catch (HttpRequestException)
        {
            _error = "Erro ao carregar lições.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnModuleFilterChangedAsync(Guid? id)
    {
        _filterModuleId = id;
        await LoadAsync();
    }

    private void InvalidateLessonPickerCache()
    {
        _lessonPickerList = [];
        _lessonPickerReady = false;
    }

    private async Task EnsureLessonPickerListAsync()
    {
        if (_lessonPickerReady)
            return;
        try
        {
            _lessonPickerList = await Http.GetFromJsonAsync<List<TeacherApp.Contracts.Lessons.LessonResponse>>("api/v1/admin/lessons") ?? [];
        }
        catch (HttpRequestException)
        {
            _lessonPickerList = [];
        }
        _lessonPickerReady = true;
    }

    private async Task OpenNewLessonAsync()
    {
        await OpenFormAsync(null);
    }

    private async Task OpenFormAsync(TeacherApp.Contracts.Lessons.LessonResponse? lesson)
    {
        await StopLessonPreviewAsync();

        if (lesson is not null)
            await EnsureLessonPickerListAsync();

        _editing = lesson;
        _audioSearchTerm = null;
        _showAudioPicker = false;
        _form = lesson is null
            ? new LessonFormModel
            {
                ModuleId = (_filterModuleId ?? _modules.FirstOrDefault()?.Id ?? Guid.Empty).ToString(),
                Order = _lessons.Count + 1
            }
            : new LessonFormModel
            {
                Title = lesson.Title,
                Description = lesson.Description,
                Order = lesson.Order,
                ModuleId = lesson.ModuleId.ToString(),
                AudioMediaId = lesson.AudioMediaId,
                AudioFileName = lesson.AudioFileName
            };
        _formError = null;
        _showForm = true;
    }

    private async Task OnSwitchEditingLessonAsync(Guid id)
    {
        if (_editing?.Id == id)
            return;
        var lesson = _lessonPickerList.FirstOrDefault(l => l.Id == id);
        if (lesson is null)
            return;
        await OpenFormAsync(lesson);
    }

    private async Task OnLessonFormVisibleChanged(bool visible)
    {
        _showForm = visible;
        if (!visible)
            await StopLessonPreviewAsync();
    }

    private async Task CloseFormAsync()
    {
        await OnLessonFormVisibleChanged(false);
    }

    private async Task Save()
    {
        _saving = true;
        _formError = null;
        try
        {
            HttpResponseMessage response;
            if (_editing is null)
            {
                if (!Guid.TryParse(_form.ModuleId, out var moduleId))
                {
                    _formError = "Selecione um módulo.";
                    return;
                }
                response = await Http.PostAsJsonAsync("api/v1/admin/lessons",
                    new TeacherApp.Contracts.Lessons.CreateLessonRequest(moduleId, _form.Title, _form.Description, _form.Order, _form.AudioMediaId));
            }
            else
            {
                if (!Guid.TryParse(_form.ModuleId, out var editModuleId))
                {
                    _formError = "Selecione um módulo.";
                    return;
                }
                response = await Http.PutAsJsonAsync($"api/v1/admin/lessons/{_editing.Id}",
                    new TeacherApp.Contracts.Lessons.UpdateLessonRequest(_form.Title, _form.Description, _form.Order, editModuleId, _form.AudioMediaId));
            }

            if (!response.IsSuccessStatusCode)
            {
                _formError = $"Erro ({(int)response.StatusCode}).";
                return;
            }

            _showForm = false;
            await StopLessonPreviewAsync();
            InvalidateLessonPickerCache();
            await LoadAsync();
        }
        catch (HttpRequestException)
        {
            _formError = "Erro de conexão.";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Delete(Guid id)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Excluir lição",
            "Tem certeza que deseja excluir esta lição?",
            yesText: "Excluir",
            cancelText: "Cancelar");
        if (confirm != true)
            return;

        try
        {
            await Http.DeleteAsync($"api/v1/admin/lessons/{id}");
            InvalidateLessonPickerCache();
            await LoadAsync();
        }
        catch (HttpRequestException)
        {
            _error = "Erro ao excluir lição.";
        }
    }

    private static readonly DialogOptions _audioPickerDialogOptions = new()
    {
        CloseButton = true,
        FullWidth = true,
        MaxWidth = MaxWidth.Small,
        BackdropClick = true
    };

    private void SelectAudio(TeacherApp.Contracts.Media.MediaResponse media)
    {
        _form.AudioMediaId = media.Id;
        _form.AudioFileName = media.FileName;
        _showAudioPicker = false;
        _audioSearchTerm = null;
    }

    private static string FormatBytes(long bytes)
    {
        return bytes switch
        {
            < 1024 => $"{bytes} B",
            < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
            _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
        };
    }

    private async Task StartLessonAudioPreviewAsync()
    {
        if (_form.AudioMediaId is not { } mediaId)
            return;

        _playingLessonPreviewName = _form.AudioFileName ?? "Áudio";
        _formError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var media = _audioMedia.FirstOrDefault(m => m.Id == mediaId);
            if (media is not null)
            {
                await LoadAudioIntoPlayerAsync(media.Id, media.ContentType);
                return;
            }

            await LoadAudioIntoPlayerAsync(mediaId, null);
        }
        catch (HttpRequestException)
        {
            _formError = "Erro de conexão ao reproduzir.";
            _playingLessonPreviewName = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadAudioIntoPlayerAsync(Guid mediaId, string? knownContentType)
    {
        var playbackResponse = await Http.GetAsync($"api/v1/media/{mediaId}/playback-url");
        if (playbackResponse.IsSuccessStatusCode)
        {
            var result = await playbackResponse.Content
                .ReadFromJsonAsync<TeacherApp.Contracts.Media.MediaPlaybackUrlResponse>();
            if (result is not null)
            {
                await JS.InvokeVoidAsync("eval",
                    $"document.getElementById('lesson-dialog-audio-player').src = '{result.Url}';");
                return;
            }
        }

        var streamResponse = await Http.GetAsync($"api/v1/media/{mediaId}");
        if (!streamResponse.IsSuccessStatusCode)
        {
            _playingLessonPreviewName = null;
            _formError = "Não foi possível reproduzir o áudio.";
            return;
        }

        var bytes = await streamResponse.Content.ReadAsByteArrayAsync();
        var base64 = Convert.ToBase64String(bytes);
        var contentType = knownContentType
            ?? streamResponse.Content.Headers.ContentType?.MediaType
            ?? "audio/mpeg";
        var dataUri = $"data:{contentType};base64,{base64}";
        await JS.InvokeVoidAsync("eval",
            $"document.getElementById('lesson-dialog-audio-player').src = '{dataUri}';");
    }

    private async Task StopLessonPreviewAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "var p = document.getElementById('lesson-dialog-audio-player'); if(p){p.pause();p.src='';}");
        }
        catch { /* ignore */ }
        _playingLessonPreviewName = null;
    }

    private async Task ClearLessonAudioAsync()
    {
        _form.AudioMediaId = null;
        _form.AudioFileName = null;
        await StopLessonPreviewAsync();
    }
}
