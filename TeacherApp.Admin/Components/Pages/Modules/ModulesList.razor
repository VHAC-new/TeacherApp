@page "/modules"
@attribute [Authorize]

@inject HttpClient Http
@inject IDialogService DialogService

<PageTitle>Módulos — TeacherApp Admin</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="my-4">
    <MudText Typo="Typo.h4">Módulos</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => OpenForm(null))">Novo Módulo</MudButton>
</MudStack>

<MudTextField T="string"
              @bind-Value="_searchTerm"
              @bind-Value:after="OnSearchChanged"
              Placeholder="Buscar módulos..."
              Adornment="Adornment.Start"
              AdornmentIcon="@Icons.Material.Filled.Search"
              Variant="Variant.Outlined"
              Margin="Margin.Dense"
              Class="mb-4"
              Immediate="true"
              DebounceInterval="250" />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (FilteredModules.Count == 0)
{
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        @(string.IsNullOrWhiteSpace(_searchTerm)
            ? "Nenhum módulo cadastrado."
            : "Nenhum resultado para a busca.")
    </MudText>
}
else
{
    <MudTable Items="@FilteredModules" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Ordem</MudTh>
            <MudTh>Título</MudTh>
            <MudTh>Descrição</MudTh>
            <MudTh>Lições</MudTh>
            <MudTh Style="width: 200px;">Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Ordem">@context.Order</MudTd>
            <MudTd DataLabel="Título">@context.Title</MudTd>
            <MudTd DataLabel="Descrição">@(context.Description ?? "—")</MudTd>
            <MudTd DataLabel="Lições">@context.LessonCount</MudTd>
            <MudTd DataLabel="Ações">
                <MudTooltip Text="Editar">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="@(() => OpenForm(context))" />
                </MudTooltip>
                <MudTooltip Text="Excluir">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => Delete(context.Id))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<MudDialog @bind-Visible="_showForm" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editing is null ? "Novo Módulo" : "Editar Módulo")</MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="_form" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_form.Title" For="@(() => _form.Title)" Label="Título" Variant="Variant.Outlined" />
                <MudTextField @bind-Value="_form.Description" Label="Descrição" Variant="Variant.Outlined" Lines="3" />
                <MudNumericField @bind-Value="_form.Order" Label="Ordem" Variant="Variant.Outlined" Min="0" />
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_formError</MudAlert>
                }
                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                    <MudButton Variant="Variant.Text" OnClick="CloseForm">Cancelar</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Disabled="_saving">
                        @if (_saving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        }
                        else
                        {
                            <span>Salvar</span>
                        }
                    </MudButton>
                </MudStack>
            </MudStack>
        </EditForm>
    </DialogContent>
</MudDialog>

@if (!string.IsNullOrEmpty(_error))
{
    <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
}

@code {
    private static readonly DialogOptions _dialogOptions = new()
    {
        CloseButton = true,
        FullWidth = true,
        MaxWidth = MaxWidth.Small,
        BackdropClick = true
    };

    private List<TeacherApp.Contracts.Modules.ModuleResponse> _modules = [];
    private bool _loading = true;
    private string? _error;
    private string? _searchTerm;

    private List<TeacherApp.Contracts.Modules.ModuleResponse> FilteredModules =>
        _modules
            .Where(m => string.IsNullOrWhiteSpace(_searchTerm)
                || m.Title.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
                || (m.Description?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
            .OrderBy(m => m.Order)
            .ToList();

    private void OnSearchChanged() { /* triggers re-render via binding */ }

    private bool _showForm;
    private bool _saving;
    private string? _formError;
    private TeacherApp.Contracts.Modules.ModuleResponse? _editing;
    private ModuleFormModel _form = new();

    private sealed class ModuleFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Título obrigatório")]
        public string Title { get; set; } = "";
        public string? Description { get; set; }
        public int Order { get; set; } = 1;
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _modules = await Http.GetFromJsonAsync<List<TeacherApp.Contracts.Modules.ModuleResponse>>("api/v1/admin/modules") ?? [];
        }
        catch (HttpRequestException)
        {
            _error = "Erro ao carregar módulos.";
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenForm(TeacherApp.Contracts.Modules.ModuleResponse? module)
    {
        _editing = module;
        _form = module is null
            ? new ModuleFormModel { Order = _modules.Count + 1 }
            : new ModuleFormModel { Title = module.Title, Description = module.Description, Order = module.Order };
        _formError = null;
        _showForm = true;
    }

    private void CloseForm() => _showForm = false;

    private async Task Save()
    {
        _saving = true;
        _formError = null;
        try
        {
            HttpResponseMessage response;
            if (_editing is null)
            {
                response = await Http.PostAsJsonAsync("api/v1/admin/modules",
                    new TeacherApp.Contracts.Modules.CreateModuleRequest(_form.Title, _form.Description, _form.Order));
            }
            else
            {
                response = await Http.PutAsJsonAsync($"api/v1/admin/modules/{_editing.Id}",
                    new TeacherApp.Contracts.Modules.UpdateModuleRequest(_form.Title, _form.Description, _form.Order));
            }

            if (!response.IsSuccessStatusCode)
            {
                _formError = $"Erro ({(int)response.StatusCode}).";
                return;
            }

            _showForm = false;
            await LoadAsync();
        }
        catch (HttpRequestException)
        {
            _formError = "Erro de conexão.";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Delete(Guid id)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Excluir módulo",
            "Tem certeza que deseja excluir este módulo?",
            yesText: "Excluir",
            cancelText: "Cancelar");
        if (confirm != true)
            return;

        try
        {
            await Http.DeleteAsync($"api/v1/admin/modules/{id}");
            await LoadAsync();
        }
        catch (HttpRequestException)
        {
            _error = "Erro ao excluir módulo.";
        }
    }
}
