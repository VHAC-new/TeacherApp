@page "/login"
@layout TeacherApp.Admin.Components.Layout.EmptyLayout

@inject HttpClient Http
@inject TokenStorageService TokenStorage
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Login — TeacherApp Admin</PageTitle>

<MudStack Justify="Justify.Center" AlignItems="AlignItems.Center" Style="min-height: 100vh;">
    <MudPaper Class="pa-6" Elevation="4" Style="width: 100%; max-width: 420px;">
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-4">TeacherApp Admin</MudText>

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">@_error</MudAlert>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_model.Email"
                              For="@(() => _model.Email)"
                              Label="E-mail"
                              Variant="Variant.Outlined"
                              Placeholder="admin@teacherapp.com"
                              InputType="InputType.Email"
                              Disabled="_loading" />
                <MudTextField @bind-Value="_model.Password"
                              For="@(() => _model.Password)"
                              Label="Senha"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Disabled="_loading" />
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="_loading">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    }
                    else
                    {
                        <span>Entrar</span>
                    }
                </MudButton>
            </MudStack>
        </EditForm>
    </MudPaper>
</MudStack>

@code {
    private LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private sealed class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "E-mail obrigatório")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "E-mail inválido")]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Senha obrigatória")]
        public string Password { get; set; } = "";
    }

    private async Task HandleLogin()
    {
        _error = null;
        _loading = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/v1/auth/login",
                new TeacherApp.Contracts.Auth.LoginRequest(_model.Email, _model.Password));

            if (!response.IsSuccessStatusCode)
            {
                _error = response.StatusCode == System.Net.HttpStatusCode.Unauthorized
                    ? "Credenciais inválidas."
                    : $"Erro ao fazer login ({(int)response.StatusCode}).";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<TeacherApp.Contracts.Auth.LoginResponse>();
            if (result is null)
            {
                _error = "Resposta inesperada do servidor.";
                return;
            }

            if (!result.Roles.Contains("Admin"))
            {
                _error = "Acesso restrito a administradores.";
                return;
            }

            TokenStorage.Store(result.AccessToken, result.Email, result.Roles, result.UserId);
            ((TeacherApp.Admin.Auth.JwtAuthenticationStateProvider)AuthStateProvider).NotifyAuthStateChanged();
            Navigation.NavigateTo("/", forceLoad: false);
        }
        catch (HttpRequestException)
        {
            _error = "Não foi possível conectar à API. Verifique se o servidor está em execução.";
        }
        finally
        {
            _loading = false;
        }
    }
}
