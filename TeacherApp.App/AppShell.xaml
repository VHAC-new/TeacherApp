<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TeacherApp.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:login="clr-namespace:TeacherApp.App.Features.Login.Views"
    xmlns:home="clr-namespace:TeacherApp.App.Features.Home.Views"
    Title="TeacherApp"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate login:LoginPage}"
        Route="login"
        Shell.NavBarIsVisible="False" />

    <ShellContent
        Title="Início"
        ContentTemplate="{DataTemplate home:HomePage}"
        Route="home" />

</Shell>
