<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fundo branco do TabBar (bg-card no Figma) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- Linha de separação superior — border-border (#E5E7EB), 2dp para ficar visível -->
    <item
        android:gravity="top"
        android:height="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#E5E7EB" />
        </shape>
    </item>
</layer-list>
