<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherApp.App.Features.Exercise.ViewModels"
             x:Class="TeacherApp.App.Features.Exercise.Views.ResultsPage"
             x:DataType="vm:ResultsViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <Grid x:Name="PageRoot" BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

        <ScrollView BackgroundColor="Transparent">
            <VerticalStackLayout x:Name="ResultsContent" Spacing="20" Padding="24,60,24,40"
                                 VerticalOptions="Center"
                                 Opacity="0"
                                 Scale="0.92"
                                 TranslationY="24">

                <!-- Trophy -->
                <Label x:Name="TrophyLabel" Text="{Binding Trophy}" FontSize="72"
                       HorizontalOptions="Center"
                       Scale="0.5" />

                <!-- Headline -->
                <Label x:Name="HeadlineLabel" Text="{Binding Headline}" FontSize="28" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="{Binding HeadlineColor}"
                       Opacity="0" TranslationY="12" />

                <Label x:Name="SubtitleLabel" Text="You've completed the lesson!"
                       FontSize="16"
                       TextColor="{AppThemeBinding Light={StaticResource MutedForeground}, Dark={StaticResource MutedForegroundDark}}"
                       HorizontalOptions="Center"
                       Opacity="0" TranslationY="12" />

                <!-- Score Card -->
                <Border x:Name="ScoreCard" Padding="24" StrokeShape="RoundRectangle 16"
                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardBackgroundDark}}"
                        Margin="0,12,0,0">
                    <Border.Shadow>
                        <Shadow Brush="#00000015" Offset="0,3" Radius="10" />
                    </Border.Shadow>

                    <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="16">

                        <!-- Score % -->
                        <VerticalStackLayout Grid.Row="0" Spacing="4"
                                             HorizontalOptions="Center">
                            <Label Text="Score" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource MutedForeground}, Dark={StaticResource MutedForegroundDark}}"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding ScorePercent, StringFormat='{0}%'}"
                                   FontSize="40" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>

                        <BoxView Grid.Row="1" HeightRequest="1"
                                 Color="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource BorderDark}}" />

                        <!-- Stats Row -->
                        <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding CorrectCount}" FontSize="22"
                                       FontAttributes="Bold" TextColor="{StaticResource Success}"
                                       HorizontalOptions="Center" />
                                <Label Text="Correct" FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource MutedForeground}, Dark={StaticResource MutedForegroundDark}}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding IncorrectCount}" FontSize="22"
                                       FontAttributes="Bold" TextColor="#F44336"
                                       HorizontalOptions="Center" />
                                <Label Text="Incorrect" FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource MutedForeground}, Dark={StaticResource MutedForegroundDark}}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding TotalCount}" FontSize="22"
                                       FontAttributes="Bold" TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center" />
                                <Label Text="Total" FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource MutedForeground}, Dark={StaticResource MutedForegroundDark}}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Buttons -->
                <VerticalStackLayout x:Name="ActionsPanel" Spacing="20" Opacity="0" TranslationY="16">
                <Button Text="Continue Learning"
                        Command="{Binding ContinueLearningCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White" FontAttributes="Bold" FontSize="16"
                        HeightRequest="54" CornerRadius="12"
                        Margin="0,16,0,0" />

                <Button Text="Review Lesson"
                        Command="{Binding ReviewLessonCommand}"
                        BackgroundColor="{AppThemeBinding Light=Transparent, Dark={StaticResource CardBackgroundDark}}"
                        TextColor="{StaticResource Primary}"
                        FontAttributes="Bold" FontSize="16"
                        HeightRequest="54" CornerRadius="12"
                        BorderColor="{StaticResource Primary}" BorderWidth="2" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
