<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherApp.App.Features.Exercise.ViewModels"
             x:Class="TeacherApp.App.Features.Exercise.Views.ExercisePage"
             x:DataType="vm:ExerciseViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <Grid x:Name="PageRoot" RowDefinitions="Auto,*">

        <!-- Gradient Header -->
        <Grid Grid.Row="0" Padding="20,16,20,20" MinimumHeightRequest="120">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource Tertiary}" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>

            <VerticalStackLayout Spacing="8" VerticalOptions="End">
                <HorizontalStackLayout Spacing="12">
                    <Label Text="&#x2190;" TextColor="White" FontSize="24"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="Practice Exercises" TextColor="White" FontSize="20"
                           FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <Label Text="{Binding QuestionLabel}" TextColor="#FFFFFFCC" FontSize="14" />

                <!-- Segmented Progress Bar -->
                <CollectionView ItemsSource="{Binding Segments}" HeightRequest="8"
                                ItemsLayout="HorizontalList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:SegmentState">
                            <Border HeightRequest="6" WidthRequest="28"
                                    Margin="1,0" StrokeShape="RoundRectangle 3"
                                    Stroke="Transparent"
                                    BackgroundColor="{Binding Color}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1"
                    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">
            <VerticalStackLayout Spacing="16" Padding="16,20,16,32">

                <Label Text="{Binding Error}" TextColor="Red" FontSize="14"
                       IsVisible="{Binding Error, Converter={StaticResource IsNotNullConverter}}" />

                <!-- Question Card -->
                <Border Padding="20" StrokeShape="RoundRectangle 14"
                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource CardBackgroundDark}}">
                    <Label Text="{Binding CurrentExercise.Prompt}" FontSize="18"
                           LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light={StaticResource Foreground}, Dark={StaticResource ForegroundDark}}" />
                </Border>

                <!-- Answer Input -->
                <Border Padding="4,0" StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardBackgroundDark}}">
                    <Entry Placeholder="Type your answer here..."
                           Text="{Binding Answer}"
                           ReturnType="Send"
                           FontSize="16"
                           Margin="12,0"
                           TextColor="{AppThemeBinding Light={StaticResource Foreground}, Dark={StaticResource ForegroundDark}}"
                           PlaceholderColor="{StaticResource MutedForeground}"
                           IsEnabled="{Binding LastResult, Converter={StaticResource IsNullConverter}}" />
                </Border>

                <!-- Collapsible Hint -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardBackgroundDark}}"
                        IsVisible="{Binding CurrentExercise.Hint, Converter={StaticResource IsNotNullOrEmptyConverter}}">
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleHintCommand}" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="&#x1F4A1;" FontSize="18" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{Binding HintToggleLabel}" FontSize="15"
                                   TextColor="{AppThemeBinding Light={StaticResource MutedForeground}, Dark={StaticResource MutedForegroundDark}}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="{Binding HintChevronGlyph}"
                                   FontFamily="MaterialIcons" FontSize="22"
                                   TextColor="{AppThemeBinding Light={StaticResource MutedForeground}, Dark={StaticResource MutedForegroundDark}}"
                                   VerticalOptions="Center" HorizontalOptions="End" />
                        </Grid>
                        <Border x:Name="HintContent"
                                IsVisible="False"
                                Padding="16,12"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 0,0,12,12"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Muted}, Dark={StaticResource SecondaryDark}}">
                            <Label Text="{Binding CurrentExercise.Hint}" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource MutedForeground}, Dark={StaticResource MutedForegroundDark}}"
                                   LineBreakMode="WordWrap" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- Result Feedback -->
                <Border IsVisible="{Binding LastResult, Converter={StaticResource IsNotNullConverter}}"
                        Padding="16" StrokeShape="RoundRectangle 12"
                        Stroke="Transparent">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding LastResult}" Value="True">
                            <Setter Property="BackgroundColor" Value="#E8F5E9" />
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding LastResult}" Value="False">
                            <Setter Property="BackgroundColor" Value="#FFEBEE" />
                        </DataTrigger>
                    </Border.Triggers>
                    <VerticalStackLayout Spacing="8">
                        <Label FontSize="20" FontAttributes="Bold">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding LastResult}" Value="True">
                                    <Setter Property="Text" Value="&#x2714; Correct!" />
                                    <Setter Property="TextColor" Value="#2E7D32" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding LastResult}" Value="False">
                                    <Setter Property="Text" Value="&#x2718; Incorrect" />
                                    <Setter Property="TextColor" Value="#C62828" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Label Text="{Binding Explanation}" FontSize="14"
                               TextColor="{StaticResource Gray600}"
                               IsVisible="{Binding Explanation, Converter={StaticResource IsNotNullConverter}}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Submit Button -->
                <Button Text="Submit Answer"
                        Command="{Binding SubmitCommand}"
                        IsVisible="{Binding LastResult, Converter={StaticResource IsNullConverter}}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White" FontAttributes="Bold" FontSize="16"
                        HeightRequest="54" CornerRadius="12" />

                <!-- Next Button -->
                <Button Text="Next Question"
                        Command="{Binding NextCommand}"
                        IsVisible="{Binding LastResult, Converter={StaticResource IsNotNullConverter}}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="{StaticResource Tertiary}"
                        TextColor="White" FontAttributes="Bold" FontSize="16"
                        HeightRequest="54" CornerRadius="12" />

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Primary}" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
