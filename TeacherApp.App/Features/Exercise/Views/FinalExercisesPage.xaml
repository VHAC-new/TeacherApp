<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherApp.App.Features.Exercise.ViewModels"
             x:Class="TeacherApp.App.Features.Exercise.Views.FinalExercisesPage"
             x:DataType="vm:FinalExercisesViewModel"
             Title="{Binding Title, StringFormat='Prova Final — {0}'}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <Label Text="{Binding Error}" TextColor="Red" FontSize="14"
                   IsVisible="{Binding Error, Converter={StaticResource IsNotNullConverter}}" />

            <!-- Finished view -->
            <VerticalStackLayout IsVisible="{Binding Finished}" Spacing="16" Padding="20">
                <Label Text="Prova concluída!" FontSize="28" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="{StaticResource Primary}" />
                <Label FontSize="20" HorizontalOptions="Center"
                       Text="{Binding CorrectCount, StringFormat='Acertos: {0}'}" />
                <Button Text="Voltar" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FinalExercisesViewModel}}, Path=LoadCommand}"
                        BackgroundColor="{StaticResource Tertiary}" TextColor="White"
                        HeightRequest="50" CornerRadius="10" />
            </VerticalStackLayout>

            <!-- Exercise view -->
            <VerticalStackLayout IsVisible="{Binding Finished, Converter={StaticResource InvertedBoolConverter}}" Spacing="16">

                <Label Text="{Binding CurrentIndex, StringFormat='Questão {0}'}"
                       FontSize="14" TextColor="{StaticResource Gray400}" />

                <Frame Padding="20" CornerRadius="12" BackgroundColor="{StaticResource Secondary}"
                       BorderColor="Transparent" HasShadow="False">
                    <Label Text="{Binding CurrentExercise.Prompt}" FontSize="18" />
                </Frame>

                <Entry Placeholder="Sua resposta"
                       Text="{Binding Answer}"
                       ReturnType="Send"
                       FontSize="18"
                       IsEnabled="{Binding LastResult, Converter={StaticResource IsNullConverter}}" />

                <!-- Result of last submission -->
                <Frame IsVisible="{Binding LastResult, Converter={StaticResource IsNotNullConverter}}"
                       Padding="16" CornerRadius="12" HasShadow="False" BorderColor="Transparent">
                    <Frame.Triggers>
                        <DataTrigger TargetType="Frame" Binding="{Binding LastResult}" Value="True">
                            <Setter Property="BackgroundColor" Value="#D4EDDA" />
                        </DataTrigger>
                        <DataTrigger TargetType="Frame" Binding="{Binding LastResult}" Value="False">
                            <Setter Property="BackgroundColor" Value="#F8D7DA" />
                        </DataTrigger>
                    </Frame.Triggers>
                    <VerticalStackLayout Spacing="8">
                        <Label FontSize="20" FontAttributes="Bold">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding LastResult}" Value="True">
                                    <Setter Property="Text" Value="Correto!" />
                                    <Setter Property="TextColor" Value="#155724" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding LastResult}" Value="False">
                                    <Setter Property="Text" Value="Incorreto" />
                                    <Setter Property="TextColor" Value="#721C24" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Label Text="{Binding Explanation}" FontSize="14"
                               IsVisible="{Binding Explanation, Converter={StaticResource IsNotNullConverter}}" />
                    </VerticalStackLayout>
                </Frame>

                <Button Text="Enviar"
                        Command="{Binding SubmitCommand}"
                        IsVisible="{Binding LastResult, Converter={StaticResource IsNullConverter}}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White" FontAttributes="Bold"
                        HeightRequest="50" CornerRadius="10" />

                <Button Text="Próxima"
                        Command="{Binding NextCommand}"
                        IsVisible="{Binding LastResult, Converter={StaticResource IsNotNullConverter}}"
                        BackgroundColor="{StaticResource Tertiary}"
                        TextColor="White"
                        HeightRequest="50" CornerRadius="10" />

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Primary}" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
