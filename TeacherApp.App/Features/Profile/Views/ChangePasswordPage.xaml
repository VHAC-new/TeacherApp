<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherApp.App.Features.Profile.ViewModels"
             x:Class="TeacherApp.App.Features.Profile.Views.ChangePasswordPage"
             x:DataType="vm:ChangePasswordViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,50,20,24" MinimumHeightRequest="120">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource Tertiary}" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>

            <VerticalStackLayout Spacing="12" VerticalOptions="End">
                <Image WidthRequest="24" HeightRequest="24" HorizontalOptions="Start">
                    <Image.Source>
                        <FontImageSource Glyph="&#xe5c4;" FontFamily="MaterialIcons" Color="White" Size="24" />
                    </Image.Source>
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Image.GestureRecognizers>
                </Image>
                <Label Text="Change Password" TextColor="White" FontSize="24" FontAttributes="Bold" />
            </VerticalStackLayout>
        </Grid>

        <!-- Form -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16" Padding="20,24,20,32">

                <Label Text="{Binding Error}" TextColor="#EF4444" FontSize="14"
                       IsVisible="{Binding Error, Converter={StaticResource IsNotNullOrEmptyConverter}}" />

                <Border Padding="4,0" StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardBackgroundDark}}">
                    <Entry Placeholder="Current password" IsPassword="True"
                           Text="{Binding CurrentPassword}"
                           FontSize="16" Margin="12,0"
                           TextColor="{AppThemeBinding Light={StaticResource Foreground}, Dark={StaticResource ForegroundDark}}"
                           PlaceholderColor="{StaticResource MutedForeground}" />
                </Border>

                <Border Padding="4,0" StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardBackgroundDark}}">
                    <Entry Placeholder="New password" IsPassword="True"
                           Text="{Binding NewPassword}"
                           FontSize="16" Margin="12,0"
                           TextColor="{AppThemeBinding Light={StaticResource Foreground}, Dark={StaticResource ForegroundDark}}"
                           PlaceholderColor="{StaticResource MutedForeground}" />
                </Border>

                <Border Padding="4,0" StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardBackgroundDark}}">
                    <Entry Placeholder="Confirm new password" IsPassword="True"
                           Text="{Binding ConfirmPassword}"
                           FontSize="16" Margin="12,0"
                           TextColor="{AppThemeBinding Light={StaticResource Foreground}, Dark={StaticResource ForegroundDark}}"
                           PlaceholderColor="{StaticResource MutedForeground}" />
                </Border>

                <Label Text="Password changed successfully!" TextColor="{StaticResource Success}"
                       FontSize="14" IsVisible="{Binding IsSuccess}" HorizontalOptions="Center" />

                <Button Text="Change Password"
                        Command="{Binding SubmitCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                        FontAttributes="Bold" FontSize="16"
                        HeightRequest="54" CornerRadius="12" Margin="0,8,0,0">
                    <Button.Shadow>
                        <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="12" Opacity="0.3" />
                    </Button.Shadow>
                </Button>

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Primary}" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
