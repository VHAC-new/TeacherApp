<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherApp.App.Features.Home.ViewModels"
             xmlns:contracts="clr-namespace:TeacherApp.Contracts.Modules;assembly=TeacherApp.Contracts"
             x:Class="TeacherApp.App.Features.Home.Views.LessonsPage"
             x:DataType="vm:LessonsViewModel"
             Title="Lessons">

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCommand}">
        <ScrollView BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource OffBlack}}">
            <VerticalStackLayout Spacing="0">

                <!-- Header gradiente -->
                <Border StrokeThickness="0" Padding="24,48,24,32"
                        StrokeShape="RoundRectangle 0,0,28,28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                            <GradientStop Color="{StaticResource Tertiary}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="My Lessons" FontSize="30" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Continue your learning journey" FontSize="16" TextColor="#E6FFFFFF" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="16" Padding="16,16,16,32">

                    <Label Text="Your Learning Modules" FontSize="20" FontAttributes="Bold" />

                    <Label Text="{Binding Error}" TextColor="Red" FontSize="14"
                           IsVisible="{Binding Error, Converter={StaticResource IsNotNullConverter}}" />

                    <CollectionView ItemsSource="{Binding Modules}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="contracts:ModuleResponse">
                                <Border Padding="20" Margin="0,0,0,12"
                                        StrokeShape="RoundRectangle 16"
                                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource Gray600}}" StrokeThickness="1"
                                        BackgroundColor="White">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LessonsViewModel}}, Path=NavigateToModuleCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" />
                                                <Label Text="{Binding LessonCount, StringFormat='{0} lessons'}"
                                                       FontSize="14" TextColor="{StaticResource Gray500}" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1" Text="›" FontSize="28" TextColor="{StaticResource Gray400}"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                        <Button Text="Continue"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:LessonsViewModel}}, Path=NavigateToModuleCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                                HeightRequest="46" CornerRadius="12" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="Nenhum módulo disponível." TextColor="{StaticResource Gray400}"
                                   HorizontalOptions="Center" Margin="0,40,0,0" />
                        </CollectionView.EmptyView>
                    </CollectionView>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
