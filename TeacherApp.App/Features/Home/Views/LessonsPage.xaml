<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherApp.App.Features.Home.ViewModels"
             xmlns:models="clr-namespace:TeacherApp.App.Features.Home.Models"
             xmlns:controls="clr-namespace:TeacherApp.App.Features.Home.Controls"
             x:Class="TeacherApp.App.Features.Home.Views.LessonsPage"
             x:DataType="vm:LessonsViewModel"
             Title="Lessons"
             BackgroundColor="#0E0D24">

    <!-- Fundo dark roxo gamificado (igual ao Figma) -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
            <GradientStop Color="#16133A" Offset="0.0" />
            <GradientStop Color="#12112A" Offset="0.5" />
            <GradientStop Color="#0E0D24" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*">

        <!-- Barra superior: mascote + streak / XP + sino -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="16,16,16,8" ColumnSpacing="8">

            <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                <Image Source="wolf_mascot.png" WidthRequest="44" HeightRequest="44" />
                <Border Padding="10,5" VerticalOptions="Center"
                        BackgroundColor="#33F59E0B" Stroke="#66F59E0B" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14">
                    <Label Text="{Binding Streak, StringFormat='⚡ {0} dias'}"
                           FontSize="12" FontAttributes="Bold" TextColor="#FBBF24" />
                </Border>
            </HorizontalStackLayout>

            <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                <Border Padding="10,5" VerticalOptions="Center"
                        BackgroundColor="#337C5DF7" Stroke="#667C5DF7" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14">
                    <Label Text="{Binding Xp, StringFormat='★ {0} XP'}"
                           FontSize="12" FontAttributes="Bold" TextColor="#C4B8FF" />
                </Border>
                <Label Text="🔔" FontSize="18" TextColor="#5A5490" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Grid>

        <!-- Conteúdo: jornada virtualizada + camadas de carregamento/erro -->
        <Grid Grid.Row="1">

            <!-- Jornada (CollectionView virtualizado por módulo) -->
            <CollectionView ItemsSource="{Binding Modules}"
                            IsVisible="{Binding IsReady}"
                            BackgroundColor="Transparent"
                            SelectionMode="None"
                            VerticalScrollBarVisibility="Never">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TrailModule">
                        <controls:ModuleTrailView
                            NodeCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:LessonsViewModel}}, Path=NavigateToNodeCommand}"
                            EnsureLoadedCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:LessonsViewModel}}, Path=EnsureModuleLoadedCommand}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.Footer>
                    <BoxView HeightRequest="32" Color="Transparent" />
                </CollectionView.Footer>
                <CollectionView.EmptyView>
                    <Label Text="Nenhum módulo disponível."
                           TextColor="#5A5490" HorizontalOptions="Center" Margin="0,60,0,0" />
                </CollectionView.EmptyView>
            </CollectionView>

            <!-- Camada "Carregando" com o lobo animado -->
            <VerticalStackLayout x:Name="LoadingOverlay"
                                 IsVisible="{Binding IsLoading}"
                                 Spacing="18"
                                 HorizontalOptions="Center" VerticalOptions="Center">
                <Image x:Name="LoadingMascot"
                       Source="wolf_mascot.png"
                       WidthRequest="96" HeightRequest="96"
                       HorizontalOptions="Center" />
                <Label Text="Carregando sua trilha…"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="#C4B8FF" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Camada de erro -->
            <VerticalStackLayout IsVisible="{Binding IsError}"
                                 Spacing="14" Padding="32"
                                 HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="{Binding Error}"
                       TextColor="#F87171" FontSize="15"
                       HorizontalTextAlignment="Center" HorizontalOptions="Center" />
                <Button Text="Tentar novamente"
                        Command="{Binding RetryCommand}"
                        BackgroundColor="#7C5DF7" TextColor="White"
                        CornerRadius="12" HeightRequest="48" Padding="24,0"
                        HorizontalOptions="Center" />
            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>
