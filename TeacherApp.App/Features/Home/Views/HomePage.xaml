<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherApp.App.Features.Home.ViewModels"
             xmlns:contracts="clr-namespace:TeacherApp.Contracts.Modules;assembly=TeacherApp.Contracts"
             x:Class="TeacherApp.App.Features.Home.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Title="Home">

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCommand}">
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- Header gradiente -->
                <Border StrokeThickness="0" Padding="24,48,24,32"
                        StrokeShape="RoundRectangle 0,0,28,28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                            <GradientStop Color="{StaticResource Tertiary}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Hello, Student!" FontSize="30" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Ready to learn today?" FontSize="16" TextColor="#E6FFFFFF" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="16" Padding="16,16,16,24">

                    <!-- Daily Streak Card -->
                    <Border StrokeThickness="0" Padding="24"
                            StrokeShape="RoundRectangle 24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F97316" Offset="0.0" />
                                <GradientStop Color="#EF4444" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="Daily Streak" FontSize="14" TextColor="#E6FFFFFF" />
                                    <HorizontalStackLayout Spacing="6" VerticalOptions="End">
                                        <Label Text="{Binding CurrentStreak}" FontSize="44" FontAttributes="Bold" TextColor="White" />
                                        <Label Text="days" FontSize="22" TextColor="#CCFFFFFF" VerticalOptions="End" Margin="0,0,0,8" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="🔥" FontSize="52" VerticalOptions="Center" />
                            </Grid>
                            <Label Text="Keep it up! You're on fire 🔥" FontSize="14" TextColor="#CCFFFFFF" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Lista de módulos -->
                    <Label Text="Modules" FontSize="20" FontAttributes="Bold" Margin="0,8,0,0" />

                    <Label Text="{Binding Error}" TextColor="Red" FontSize="14"
                           IsVisible="{Binding Error, Converter={StaticResource IsNotNullConverter}}" />

                    <CollectionView ItemsSource="{Binding Modules}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="contracts:ModuleResponse">
                                <Border Padding="16" Margin="0,0,0,8"
                                        StrokeShape="RoundRectangle 16"
                                        Stroke="{StaticResource Gray200}" StrokeThickness="1"
                                        BackgroundColor="White">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToModuleCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" />
                                        <Label Text="{Binding Description}" FontSize="14" TextColor="{StaticResource Gray500}"
                                               LineBreakMode="TailTruncation" MaxLines="2" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="Nenhum módulo disponível." TextColor="{StaticResource Gray400}"
                                   HorizontalOptions="Center" Margin="0,40,0,0" />
                        </CollectionView.EmptyView>
                    </CollectionView>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
