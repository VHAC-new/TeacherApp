<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherApp.App.Features.Home.ViewModels"
             xmlns:contracts="clr-namespace:TeacherApp.Contracts.Modules;assembly=TeacherApp.Contracts"
             x:Class="TeacherApp.App.Features.Home.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Title="Início">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" Padding="0,0,10,0">
            <Label Text="TeacherApp" FontSize="20" FontAttributes="Bold"
                   VerticalOptions="Center" TextColor="White" />
            <Button Grid.Column="1" Text="Sair" Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent" TextColor="White" FontSize="14" />
        </Grid>
    </Shell.TitleView>

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCommand}">
        <ScrollView>
            <VerticalStackLayout Spacing="16" Padding="16">

                <Label Text="Módulos" FontSize="24" FontAttributes="Bold" />

                <Label Text="{Binding Error}" TextColor="Red" FontSize="14"
                       IsVisible="{Binding Error, Converter={StaticResource IsNotNullConverter}}" />

                <CollectionView ItemsSource="{Binding Modules}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="contracts:ModuleResponse">
                            <Frame Padding="16" Margin="0,0,0,8" CornerRadius="12"
                                   BorderColor="{StaticResource Gray200}" HasShadow="True"
                                   BackgroundColor="White">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=NavigateToModuleCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" />
                                    <Label Text="{Binding Description}" FontSize="14" TextColor="{StaticResource Gray500}"
                                           LineBreakMode="TailTruncation" MaxLines="2" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="Nenhum módulo disponível." TextColor="{StaticResource Gray400}"
                               HorizontalOptions="Center" Margin="0,40,0,0" />
                    </CollectionView.EmptyView>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
