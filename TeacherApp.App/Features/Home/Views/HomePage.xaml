<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherApp.App.Features.Home.ViewModels"
             x:Class="TeacherApp.App.Features.Home.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             Title="Home">

    <RefreshView IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshCommand}">
        <ScrollView BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">
            <VerticalStackLayout Spacing="0">

                <!-- Header gradiente -->
                <Border StrokeThickness="0" Padding="24,48,24,32"
                        StrokeShape="RoundRectangle 0,0,28,28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                            <GradientStop Color="{StaticResource Tertiary}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Hello, Student!" FontSize="30" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Ready to learn today?" FontSize="16" TextColor="#E6FFFFFF" />
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="16" Padding="16,16,16,32">

                    <!-- Daily Streak Card -->
                    <Border StrokeThickness="0" Padding="24"
                            StrokeShape="RoundRectangle 24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F97316" Offset="0.0" />
                                <GradientStop Color="#EF4444" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                    <Label Text="Daily Streak" FontSize="14" TextColor="#E6FFFFFF" />
                                    <HorizontalStackLayout Spacing="6" VerticalOptions="End">
                                        <Label Text="{Binding CurrentStreak}" FontSize="44" FontAttributes="Bold" TextColor="White" />
                                        <Label Text="days" FontSize="22" TextColor="#CCFFFFFF" VerticalOptions="End" Margin="0,0,0,8" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="🔥" FontSize="52" VerticalOptions="Center" />
                            </Grid>
                            <Label Text="Keep it up! You're on fire 🔥" FontSize="14" TextColor="#CCFFFFFF" />
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{Binding Error}" TextColor="Red" FontSize="14"
                           IsVisible="{Binding Error, Converter={StaticResource IsNotNullConverter}}" />

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
