<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherApp.App.Features.Lesson.ViewModels"
             x:Class="TeacherApp.App.Features.Lesson.Views.LessonPage"
             x:DataType="vm:LessonViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">

    <Grid RowDefinitions="Auto,*">

        <!-- Gradient Header -->
        <Grid Grid.Row="0" Padding="20,16,20,24" MinimumHeightRequest="100">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource Tertiary}" Offset="1.0" />
                </LinearGradientBrush>
            </Grid.Background>

            <VerticalStackLayout Spacing="8" VerticalOptions="End">
                <Image WidthRequest="24" HeightRequest="24"
                       HorizontalOptions="Start">
                    <Image.Source>
                        <FontImageSource Glyph="&#xe5c4;"
                                         FontFamily="MaterialIcons"
                                         Color="White" Size="24" />
                    </Image.Source>
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Image.GestureRecognizers>
                </Image>
                <Label Text="{Binding Title}" TextColor="White" FontSize="22"
                       FontAttributes="Bold"
                       LineBreakMode="TailTruncation" MaxLines="2" />
            </VerticalStackLayout>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1" BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource PageBackgroundDark}}">
            <VerticalStackLayout Spacing="20" Padding="16,20,16,32">

                <!-- Reading Card -->
                <Border IsVisible="{Binding HasDescription}"
                        Padding="20" StrokeShape="RoundRectangle 16"
                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardBackgroundDark}}">
                    <Border.Shadow>
                        <Shadow Brush="#00000010" Offset="0,2" Radius="8" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#x1F4D6;" FontSize="20" VerticalOptions="Center" />
                            <Label Text="Reading" FontSize="18" FontAttributes="Bold"
                                   VerticalOptions="Center" TextColor="{StaticResource Primary}" />
                        </HorizontalStackLayout>
                        <Label Text="{Binding Description}" FontSize="15"
                               TextColor="{AppThemeBinding Light={StaticResource MutedForeground}, Dark={StaticResource MutedForegroundDark}}"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Audio Player -->
                <ActivityIndicator IsRunning="{Binding IsAudioLoading}"
                                   IsVisible="{Binding IsAudioLoading}"
                                   Color="{StaticResource Primary}"
                                   HorizontalOptions="Center" />

                <Label Text="{Binding AudioLoadError}" TextColor="Red" FontSize="13"
                       IsVisible="{Binding AudioLoadError, Converter={StaticResource IsNotNullOrEmptyConverter}}" />

                <Border IsVisible="{Binding HasLessonAudio}"
                        Padding="12" StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light={StaticResource CardBorder}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource CardBackgroundDark}}">
                    <Grid IsVisible="{Binding IsAudioLoading, Converter={StaticResource InvertedBoolConverter}}"
                          ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12"
                          VerticalOptions="Center">
                            <!-- Play button -->
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    StrokeShape="RoundRectangle 20"
                                    Stroke="Transparent"
                                    StrokeThickness="0"
                                    BackgroundColor="{StaticResource Primary}"
                                    VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding TogglePlayCommand}" />
                                </Border.GestureRecognizers>
                                <Image WidthRequest="22" HeightRequest="22"
                                       HorizontalOptions="Center" VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource Glyph="{Binding PlayButtonGlyph}"
                                                         FontFamily="MaterialIcons"
                                                         Color="White" Size="22" />
                                    </Image.Source>
                                </Image>
                            </Border>

                            <!-- Label + progress -->
                            <VerticalStackLayout Grid.Column="1" Spacing="6"
                                                 VerticalOptions="Center">
                                <Label Text="Listen to the pronunciation"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource MutedForeground}, Dark={StaticResource MutedForegroundDark}}"
                                       LineBreakMode="TailTruncation" />
                                <ProgressBar Progress="{Binding AudioProgress}"
                                             ProgressColor="{StaticResource Primary}"
                                             BackgroundColor="#D6CFF0"
                                             HeightRequest="4" />
                            </VerticalStackLayout>

                            <!-- Time -->
                            <Label Grid.Column="2"
                                   Text="{Binding AudioTimeDisplay}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource MutedForeground}, Dark={StaticResource MutedForegroundDark}}"
                                   VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Continue Button -->
                <Button Text="Continue to Exercises"
                        Command="{Binding ContinueToExercisesCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White" FontAttributes="Bold" FontSize="16"
                        HeightRequest="54" CornerRadius="12"
                        Margin="0,8,0,0">
                    <Button.Shadow>
                        <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="12" Opacity="0.3" />
                    </Button.Shadow>
                </Button>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading Overlay -->
        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Primary}" VerticalOptions="Center"
                           HorizontalOptions="Center" />

    </Grid>
</ContentPage>
