<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherApp.App.Features.Lesson.ViewModels"
             x:Class="TeacherApp.App.Features.Lesson.Views.LessonPage"
             x:DataType="vm:LessonViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0E0D24">

    <!-- Fundo dark roxo gamificado (igual ao restante do app) -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
            <GradientStop Color="#16133A" Offset="0.0" />
            <GradientStop Color="#12112A" Offset="0.5" />
            <GradientStop Color="#0E0D24" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="8" Padding="20,16,20,12">
            <Image WidthRequest="24" HeightRequest="24" HorizontalOptions="Start">
                <Image.Source>
                    <FontImageSource Glyph="&#xe5c4;"
                                     FontFamily="MaterialIcons"
                                     Color="#E8ECF4" Size="24" />
                </Image.Source>
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Image.GestureRecognizers>
            </Image>
            <Label Text="{Binding Title}" TextColor="#E8ECF4" FontSize="22"
                   FontAttributes="Bold"
                   LineBreakMode="TailTruncation" MaxLines="2" />
        </VerticalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1" BackgroundColor="Transparent">
            <VerticalStackLayout Spacing="20" Padding="16,12,16,32">

                <!-- Reading Card -->
                <Border IsVisible="{Binding HasDescription}"
                        Padding="20" StrokeShape="RoundRectangle 16"
                        Stroke="#2A2650" StrokeThickness="1"
                        BackgroundColor="#1A1E2E">
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#x1F4D6;" FontSize="20" VerticalOptions="Center" />
                            <Label Text="Leitura" FontSize="18" FontAttributes="Bold"
                                   VerticalOptions="Center" TextColor="#7C5DF7" />
                        </HorizontalStackLayout>
                        <Label Text="{Binding Description}" FontSize="15"
                               TextColor="#E8ECF4"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- Audio Player -->
                <ActivityIndicator IsRunning="{Binding IsAudioLoading}"
                                   IsVisible="{Binding IsAudioLoading}"
                                   Color="#7C5DF7"
                                   HorizontalOptions="Center" />

                <Label Text="{Binding AudioLoadError}" TextColor="#F87171" FontSize="13"
                       IsVisible="{Binding AudioLoadError, Converter={StaticResource IsNotNullOrEmptyConverter}}" />

                <Border IsVisible="{Binding HasLessonAudio}"
                        Padding="12" StrokeShape="RoundRectangle 12"
                        Stroke="#2A2650" StrokeThickness="1"
                        BackgroundColor="#1A1E2E">
                    <Grid IsVisible="{Binding IsAudioLoading, Converter={StaticResource InvertedBoolConverter}}"
                          ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12"
                          VerticalOptions="Center">
                            <!-- Play button -->
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    StrokeShape="RoundRectangle 20"
                                    Stroke="Transparent"
                                    StrokeThickness="0"
                                    BackgroundColor="#7C5DF7"
                                    VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding TogglePlayCommand}" />
                                </Border.GestureRecognizers>
                                <Image WidthRequest="22" HeightRequest="22"
                                       HorizontalOptions="Center" VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource Glyph="{Binding PlayButtonGlyph}"
                                                         FontFamily="MaterialIcons"
                                                         Color="White" Size="22" />
                                    </Image.Source>
                                </Image>
                            </Border>

                            <!-- Label + progress -->
                            <VerticalStackLayout Grid.Column="1" Spacing="6"
                                                 VerticalOptions="Center">
                                <Label Text="Ouça a pronúncia"
                                       FontSize="13"
                                       TextColor="#8A85B8"
                                       LineBreakMode="TailTruncation" />
                                <ProgressBar Progress="{Binding AudioProgress}"
                                             ProgressColor="#7C5DF7"
                                             BackgroundColor="#2A2650"
                                             HeightRequest="4" />
                            </VerticalStackLayout>

                            <!-- Time -->
                            <Label Grid.Column="2"
                                   Text="{Binding AudioTimeDisplay}"
                                   FontSize="12"
                                   TextColor="#8A85B8"
                                   VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Continue Button -->
                <Button Text="Continuar para os exercícios"
                        Command="{Binding ContinueToExercisesCommand}"
                        BackgroundColor="#7C5DF7"
                        TextColor="White" FontAttributes="Bold" FontSize="16"
                        HeightRequest="54" CornerRadius="14"
                        Margin="0,8,0,0">
                    <Button.Shadow>
                        <Shadow Brush="#7C5DF7" Offset="0,4" Radius="12" Opacity="0.3" />
                    </Button.Shadow>
                </Button>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Loading Overlay -->
        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           Color="#7C5DF7" VerticalOptions="Center"
                           HorizontalOptions="Center" />

    </Grid>
</ContentPage>
