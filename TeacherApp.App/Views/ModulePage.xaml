<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TeacherApp.App.ViewModels"
             xmlns:contracts="clr-namespace:TeacherApp.Contracts.Lessons;assembly=TeacherApp.Contracts"
             x:Class="TeacherApp.App.Views.ModulePage"
             x:DataType="vm:ModuleViewModel"
             Title="{Binding Title}">

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCommand}">
        <ScrollView>
            <VerticalStackLayout Spacing="16" Padding="16">

                <Label Text="Lições" FontSize="24" FontAttributes="Bold" />

                <Label Text="{Binding Error}" TextColor="Red" FontSize="14"
                       IsVisible="{Binding Error, Converter={StaticResource IsNotNullConverter}}" />

                <CollectionView ItemsSource="{Binding Lessons}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="contracts:LessonResponse">
                            <Frame Padding="16" Margin="0,0,0,8" CornerRadius="12"
                                   BorderColor="{StaticResource Gray200}" HasShadow="True"
                                   BackgroundColor="White">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ModuleViewModel}}, Path=NavigateToLessonCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" />
                                    <Label Text="{Binding Description}" FontSize="14"
                                           TextColor="{StaticResource Gray500}"
                                           LineBreakMode="TailTruncation" MaxLines="2" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="Nenhuma lição disponível." TextColor="{StaticResource Gray400}"
                               HorizontalOptions="Center" Margin="0,40,0,0" />
                    </CollectionView.EmptyView>
                </CollectionView>

                <Button Text="Exercícios Finais do Módulo"
                        Command="{Binding NavigateToFinalExercisesCommand}"
                        BackgroundColor="{StaticResource Tertiary}"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50"
                        Margin="0,8,0,0" />

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
